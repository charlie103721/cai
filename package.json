{
	"name": "cai",
	"type": "module",
	"scripts": {
		"serve:client": "vite --host",
		"serve:server": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun --watch run --env-file=.env server/dev.ts",
		"local": "concurrently --kill-others-on-fail -n client,server -c blue,green \"bun run serve:client\" \"bun run serve:server\"",
		"build": "vite build",
		"preview": "bun run build && wrangler dev",
		"deploy": "bun run build && bun run db:migrate:prod && wrangler deploy",
		"db:migrate:prod": "wrangler d1 migrations apply cai-db --remote",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"test": "vitest",
		"test:run": "vitest run",
		"test:server": "vitest --project server",
		"test:client": "vitest --project client",
		"lint": "eslint .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"secrets:push": "bun scripts/push-secrets.ts",
		"secrets:github": "bun scripts/push-github-secrets.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.111.0",
		"@tailwindcss/vite": "4.1.18",
		"@tanstack/react-query": "5.90.21",
		"better-auth": "1.4.18",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"drizzle-orm": "0.45.1",
		"hono": "4.11.9",
		"lucide-react": "0.564.0",
		"radix-ui": "1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-icons": "5.5.0",
		"react-router": "7.13.0",
		"sonner": "2.0.7",
		"tailwind-merge": "3.4.0",
		"tailwindcss": "4.1.18",
		"usehooks-ts": "3.1.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "25.2.3",
		"better-sqlite3": "^12.9.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.4",
		"@vitest/browser": "4.0.18",
		"concurrently": "9.2.1",
		"drizzle-kit": "0.31.9",
		"eslint": "10.0.0",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.5.0",
		"globals": "17.3.0",
		"jsdom": "28.0.0",
		"shadcn": "3.8.4",
		"tsx": "4.21.0",
		"tw-animate-css": "1.4.0",
		"typescript-eslint": "8.55.0",
		"vite": "6.4.1",
		"vitest": "4.0.18",
		"wrangler": "4.65.0"
	}
}
