# ===========================================
# Local Development Environment Variables
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# --- App Stage ---
APP_STAGE=dev

# --- Server port (Hono) ---
PORT=8443

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=dev-secret-key-for-local-smoke-test-only-0001
BETTER_AUTH_URL=http://localhost:5173

# --- OAuth: GitHub (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth: Google (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Claude API (chat engine) ---
ANTHROPIC_API_KEY=
# Optional: override the chat model (default: claude-haiku-4-5)
# ANTHROPIC_MODEL=

# --- Client ---
CLIENT_URL=http://localhost:5173

# --- Vite (client-side, prefix with VITE_) ---
# VITE_API_URL=
